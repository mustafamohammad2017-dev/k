@page "/edit-employee/{employeeId:int}"
@using EmployeePromotionSystem.Services
@using EmployeePromotionSystem.Models
@inject IEmployeeService EmployeeService
@inject IJSRuntime JSRuntime

<PageTitle>تعديل بيانات الموظف - نظام أتمتة العلاوات والترفيعات</PageTitle>

<div class="edit-employee-container">
    <!-- رأس الصفحة -->
    <div class="page-header animate__animated animate__fadeInDown">
        <h1 class="page-title">
            <i class="fas fa-user-edit"></i>
            تعديل بيانات الموظف
        </h1>
        <p class="page-subtitle">@(employee?.FullName ?? "جاري التحميل...")</p>
    </div>

    @if (employee == null)
    {
        <div class="loading-container">
            <div class="loading-spinner">
                <i class="fas fa-spinner fa-spin"></i>
            </div>
            <p>جاري تحميل بيانات الموظف...</p>
        </div>
    }
    else
    {
        <!-- نموذج تعديل الموظف -->
        <div class="employee-form animate__animated animate__fadeInUp">
            <EditForm Model="employee" OnValidSubmit="UpdateEmployee">
                <DataAnnotationsValidator />
                
                <!-- القسم الأول: البيانات الشخصية -->
                <div class="form-section">
                    <div class="section-header">
                        <h3 class="section-title">
                            <i class="fas fa-user"></i>
                            البيانات الشخصية
                        </h3>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-8">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-signature"></i>
                                    الاسم الرباعي واللقب *
                                </label>
                                <InputText @bind-Value="employee.FullName" class="form-control" 
                                         placeholder="أدخل الاسم الرباعي كاملاً" />
                                <ValidationMessage For="@(() => employee.FullName)" class="validation-message" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-id-badge"></i>
                                    اللقب العلمي
                                </label>
                                <InputText @bind-Value="employee.Title" class="form-control" 
                                         placeholder="مثل: دكتور، أستاذ، مهندس" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-graduation-cap"></i>
                                    الشهادة العلمية
                                </label>
                                <select @bind="employee.AcademicDegree" class="form-control">
                                    <option value="">اختر الشهادة العلمية</option>
                                    <option value="دبلوم">دبلوم</option>
                                    <option value="بكالوريوس">بكالوريوس</option>
                                    <option value="ماجستير">ماجستير</option>
                                    <option value="دكتوراه">دكتوراه</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-briefcase"></i>
                                    صنف الوظيفة *
                                </label>
                                <select @bind="employee.JobCategory" class="form-control">
                                    <option value="">اختر صنف الوظيفة</option>
                                    <option value="تدريسي">تدريسي</option>
                                    <option value="إداري">إداري</option>
                                    <option value="فني">فني</option>
                                    <option value="خدمي">خدمي</option>
                                </select>
                                <ValidationMessage For="@(() => employee.JobCategory)" class="validation-message" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- القسم الثاني: البيانات الوظيفية -->
                <div class="form-section">
                    <div class="section-header">
                        <h3 class="section-title">
                            <i class="fas fa-building"></i>
                            البيانات الوظيفية
                        </h3>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-layer-group"></i>
                                    الدرجة الوظيفية *
                                </label>
                                <select @bind="employee.JobGrade" class="form-control">
                                    <option value="0">اختر الدرجة</option>
                                    @for (int i = 1; i <= 10; i++)
                                    {
                                        <option value="@i">الدرجة @i</option>
                                    }
                                </select>
                                <ValidationMessage For="@(() => employee.JobGrade)" class="validation-message" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-stairs"></i>
                                    المرحلة الوظيفية *
                                </label>
                                <select @bind="employee.JobStage" class="form-control">
                                    <option value="0">اختر المرحلة</option>
                                    @for (int i = 1; i <= 11; i++)
                                    {
                                        <option value="@i">المرحلة @i</option>
                                    }
                                </select>
                                <ValidationMessage For="@(() => employee.JobStage)" class="validation-message" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-hashtag"></i>
                                    العنوان الوظيفي (رقم)
                                </label>
                                <InputNumber @bind-Value="employee.JobTitle" class="form-control" 
                                           placeholder="أدخل رقم العنوان الوظيفي" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-chart-line"></i>
                                    مؤشر تتبع العلاوة *
                                </label>
                                <select @bind="employee.AllowanceTracker" class="form-control">
                                    <option value="">اختر مؤشر التتبع</option>
                                    <option value="0/4">0/4</option>
                                    <option value="1/4">1/4</option>
                                    <option value="2/4">2/4</option>
                                    <option value="3/4">3/4</option>
                                    <option value="0/5">0/5</option>
                                    <option value="1/5">1/5</option>
                                    <option value="2/5">2/5</option>
                                    <option value="3/5">3/5</option>
                                    <option value="4/5">4/5</option>
                                </select>
                                <ValidationMessage For="@(() => employee.AllowanceTracker)" class="validation-message" />
                                <small class="form-text">
                                    <i class="fas fa-info-circle"></i>
                                    للدرجات 10-6 استخدم X/4، للدرجات 5-2 استخدم X/5
                                </small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- القسم الثالث: التواريخ المهمة -->
                <div class="form-section">
                    <div class="section-header">
                        <h3 class="section-title">
                            <i class="fas fa-calendar"></i>
                            التواريخ المهمة
                        </h3>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-calendar-plus"></i>
                                    تاريخ المباشرة بالوظيفة *
                                </label>
                                <InputDate @bind-Value="employee.StartDate" class="form-control" />
                                <ValidationMessage For="@(() => employee.StartDate)" class="validation-message" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-calendar-check"></i>
                                    تاريخ آخر استحقاق للعلاوة *
                                </label>
                                <InputDate @bind-Value="employee.LastAllowanceDate" class="form-control" />
                                <ValidationMessage For="@(() => employee.LastAllowanceDate)" class="validation-message" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-calendar-alt"></i>
                                    آخر تاريخ استحقاق للترفيع *
                                </label>
                                <InputDate @bind-Value="employee.LastPromotionDate" class="form-control" />
                                <ValidationMessage For="@(() => employee.LastPromotionDate)" class="validation-message" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- أزرار الحفظ والإلغاء -->
                <div class="form-actions">
                    <button type="submit" class="btn btn-success btn-lg" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <i class="fas fa-spinner fa-spin"></i>
                            <span>جاري الحفظ...</span>
                        }
                        else
                        {
                            <i class="fas fa-save"></i>
                            <span>حفظ التغييرات</span>
                        }
                    </button>
                    <button type="button" class="btn btn-secondary btn-lg" @onclick="Cancel">
                        <i class="fas fa-times"></i>
                        إلغاء
                    </button>
                    <button type="button" class="btn btn-info btn-lg" @onclick="ViewProfile">
                        <i class="fas fa-eye"></i>
                        عرض الملف
                    </button>
                </div>
            </EditForm>
        </div>
    }
</div>

<!-- رسائل النجاح والخطأ -->
@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible animate__animated animate__bounceIn">
        <i class="fas fa-check-circle"></i>
        @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = string.Empty"></button>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible animate__animated animate__shakeX">
        <i class="fas fa-exclamation-triangle"></i>
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
    </div>
}

<style>
    .edit-employee-container {
        padding: 20px 0;
        max-width: 1000px;
        margin: 0 auto;
    }

    .page-header {
        text-align: center;
        margin-bottom: 30px;
    }

    .page-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .page-title i {
        margin-left: 15px;
        color: #667eea;
    }

    .page-subtitle {
        color: #666;
        font-size: 1.1rem;
        font-weight: 600;
    }

    .employee-form {
        background: white;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
    }

    .form-section {
        margin-bottom: 40px;
        padding-bottom: 30px;
        border-bottom: 2px solid #f8f9fa;
    }

    .form-section:last-of-type {
        border-bottom: none;
        margin-bottom: 20px;
    }

    .section-header {
        margin-bottom: 25px;
    }

    .section-title {
        font-size: 1.4rem;
        font-weight: 600;
        color: #333;
        display: flex;
        align-items: center;
        margin: 0;
    }

    .section-title i {
        margin-left: 12px;
        color: #667eea;
        font-size: 1.2rem;
    }

    .form-group {
        margin-bottom: 25px;
    }

    .form-label {
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        font-size: 1rem;
    }

    .form-label i {
        margin-left: 8px;
        color: #667eea;
        font-size: 0.9rem;
    }

    .form-control {
        border: 2px solid #e9ecef;
        border-radius: 10px;
        padding: 12px 15px;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: #fafbfc;
    }

    .form-control:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
        background: white;
    }

    .form-text {
        color: #6c757d;
        font-size: 0.875rem;
        margin-top: 5px;
        display: flex;
        align-items: center;
    }

    .form-text i {
        margin-left: 5px;
        color: #ffc107;
    }

    .validation-message {
        color: #dc3545;
        font-size: 0.875rem;
        margin-top: 5px;
        display: flex;
        align-items: center;
    }

    .validation-message::before {
        content: "⚠️";
        margin-left: 5px;
    }

    .form-actions {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin-top: 30px;
        padding-top: 30px;
        border-top: 2px solid #f8f9fa;
    }

    .btn {
        border-radius: 10px;
        font-weight: 600;
        padding: 12px 30px;
        font-size: 1.1rem;
        transition: all 0.3s ease;
        display: flex;
