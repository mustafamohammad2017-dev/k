    }

    .alert-success {
        background: linear-gradient(135deg, #28a745, #20c997);
        color: white;
        border: none;
    }

    .alert-danger {
        background: linear-gradient(135deg, #dc3545, #e74c3c);
        color: white;
        border: none;
    }

    .btn-close {
        background: none;
        border: none;
        color: white;
        font-size: 1.2rem;
