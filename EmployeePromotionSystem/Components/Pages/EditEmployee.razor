        }

        .employee-form {
            padding: 20px;
        }

        .page-title {
            font-size: 2rem;
        }

        .form-actions {
            flex-direction: column;
        }

        .alert {
            min-width: 90%;
            left: 5%;
            transform: none;
        }
    }
</style>

@code {
    [Parameter] public int EmployeeId { get; set; }
    
    private Employee? employee;
    private bool isSaving = false;
    private string successMessage = string.Empty;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployee();
    }

    private async Task LoadEmployee()
    {
        try
        {
            employee = await EmployeeService.GetEmployeeByIdAsync(EmployeeId);
            if (employee == null)
            {
                errorMessage = "لم يتم العثور على الموظف المطلوب";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"خطأ في تحميل بيانات الموظف: {ex.Message}";
        }
    }

    private async Task UpdateEmployee()
    {
        try
        {
            isSaving = true;
            errorMessage = string.Empty;

            // التحقق من صحة البيانات
            if (string.IsNullOrWhiteSpace(employee.FullName))
            {
                errorMessage = "اسم الموظف مطلوب";
                return;
            }

            if (string.IsNullOrWhiteSpace(employee.JobCategory))
            {
                errorMessage = "صنف الوظيفة مطلوب";
                return;
            }

            if (employee.JobGrade < 1 || employee.JobGrade > 10)
            {
                errorMessage = "الدرجة الوظيفية يجب أن تكون بين 1 و 10";
                return;
            }

            if (employee.JobStage < 1 || employee.JobStage > 11)
            {
                errorMessage = "المرحلة الوظيفية يجب أن تكون بين 1 و 11";
                return;
            }

            if (string.IsNullOrWhiteSpace(employee.AllowanceTracker))
            {
                errorMessage = "مؤشر تتبع العلاوة مطلوب";
                return;
            }

            // تحديث الموظف
            await EmployeeService.UpdateEmployeeAsync(employee);

            successMessage = $"تم تحديث بيانات الموظف {employee.FullName} بنجاح!";

            // إخفاء رسالة النجاح بعد 3 ثوان
            _ = Task.Delay(3000).ContinueWith(_ => 
            {
                successMessage = string.Empty;
                InvokeAsync(StateHasChanged);
            });
        }
        catch (Exception ex)
        {
            errorMessage = $"حدث خطأ أثناء تحديث البيانات: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task Cancel()
    {
        await JSRuntime.InvokeVoidAsync("window.location.href", "/employees");
    }

    private async Task ViewProfile()
    {
        await JSRuntime.InvokeVoidAsync("window.location.href", $"/employee/{EmployeeId}");
    }
}

