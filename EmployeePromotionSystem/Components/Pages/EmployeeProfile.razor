    }

    .employee-basic-info {
        flex: 1;
    }

    .employee-name {
        font-size: 2.5rem;
        font-weight: 700;
        color: #333;
        margin: 0 0 15px 0;
    }

    .name-input {
        font-size: 2rem;
        font-weight: 700;
        border: 2px solid #667eea;
