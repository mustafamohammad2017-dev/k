    }

    .status-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: #28a745;
        animation: pulse 2s infinite;
    }

    .status-text {
        color: #28a745;
        font-weight: 600;
    }

    @keyframes pulse {
        0% { opacity: 1; }
        50% { opacity: 0.5; }
        100% { opacity: 1; }
    }

    .header-actions {
        flex-shrink: 0;
        display: flex;
        gap: 10px;
        flex-direction: column;
    }

    .key-metrics {
