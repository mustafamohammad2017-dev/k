    }

    .timeline-impact {
        color: #28a745;
        font-weight: 500;
    }

    .events-list {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .event-item {
        display: flex;
        align-items: flex-start;
        gap: 20px;
        padding: 20px;
        border-radius: 10px;
        border-left: 4px solid;
    }

    .event-item.positive {
        background: #f8fff9;
        border-left-color: #28a745;
    }

    .event-item.negative {
        background: #fff8f8;
        border-left-color: #dc3545;
    }

    .event-item.neutral {
        background: #f8f9fa;
        border-left-color: #6c757d;
    }

    .event-icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .event-item.positive .event-icon {
        background: #28a745;
    }

    .event-item.negative .event-icon {
        background: #dc3545;
    }

    .event-item.neutral .event-icon {
        background: #6c757d;
    }

    .event-content {
        flex: 1;
    }

    .event-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
    }

    .event-title {
        font-size: 1rem;
        font-weight: 600;
        color: #333;
        margin: 0;
    }

    .event-date {
        color: #666;
        font-size: 0.9rem;
        font-weight: 500;
    }

    .event-description {
        color: #666;
        margin: 0 0 8px 0;
        line-height: 1.4;
    }

    .event-document {
        color: #999;
        font-size: 0.8rem;
        display: block;
        margin-bottom: 5px;
    }

    .event-impact {
        font-weight: 600;
        font-size: 0.9rem;
    }

    .event-item.positive .event-impact {
        color: #28a745;
    }

    .event-item.negative .event-impact {
        color: #dc3545;
    }

    .no-records {
        text-align: center;
        padding: 60px 20px;
        color: #666;
    }

    .no-records i {
        font-size: 4rem;
        color: #ccc;
        margin-bottom: 20px;
    }

    .loading-container {
        text-align: center;
        padding: 100px 20px;
        color: #666;
    }

    .loading-spinner i {
        font-size: 3rem;
        color: #667eea;
        margin-bottom: 20px;
    }

    @media (max-width: 768px) {
        .profile-header {
            flex-direction: column;
            text-align: center;
            gap: 20px;
        }

        .employee-name {
            font-size: 2rem;
        }

        .info-row {
            justify-content: center;
        }

        .timeline-item {
            padding-right: 60px;
        }

        .career-timeline::before {
            right: 20px;
        }

        .timeline-marker {
            right: 5px;
        }
    }
</style>

@code {
    [Parameter] public int EmployeeId { get; set; }
    
    private Employee? employee;
    private Employee editEmployee = new();
    private List<PromotionHistory>? promotionHistory;
    private List<ProfessionalEvent>? professionalEvents;
    
    private DateTime nextEntitlementDate;
    private int daysUntilEntitlement;
    private string activeTab = "career";
    private bool isEditingBasicInfo = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployeeData();
    }

    private async Task LoadEmployeeData()
    {
        try
        {
            employee = await EmployeeService.GetEmployeeByIdAsync(EmployeeId);
            if (employee != null)
            {
                editEmployee = new Employee
                {
                    Id = employee.Id,
                    FullName = employee.FullName,
                    Title = employee.Title,
                    JobCategory = employee.JobCategory,
                    AcademicDegree = employee.AcademicDegree
                };

                // حساب الاستحقاق القادم
                await CalculationEngine.ProcessEmployeeEntitlementsAsync(employee);
                
                // حساب الأيام المتبقية
                nextEntitlementDate = employee.NextEntitlementDate;
                daysUntilEntitlement = (nextEntitlementDate - DateTime.Today).Days;

                // تحميل السجلات
                promotionHistory = await EmployeeService.GetPromotionHistoryAsync(EmployeeId);
                professionalEvents = await EmployeeService.GetProfessionalEventsAsync(EmployeeId);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"خطأ في تحميل بيانات الموظف: {ex.Message}");
        }
    }

    private void SetActiveTab(string tab)
    {
        activeTab = tab;
    }

    private void EditBasicInfo()
    {
        isEditingBasicInfo = true;
    }

    private async Task SaveBasicInfo()
    {
        try
        {
            employee.FullName = editEmployee.FullName;
            employee.Title = editEmployee.Title;
            employee.JobCategory = editEmployee.JobCategory;
            employee.AcademicDegree = editEmployee.AcademicDegree;

            await EmployeeService.UpdateEmployeeAsync(employee);
            isEditingBasicInfo = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"خطأ في حفظ البيانات: {ex.Message}");
        }
    }

    private void CancelEditBasicInfo()
    {
        editEmployee.FullName = employee.FullName;
        editEmployee.Title = employee.Title;
        editEmployee.JobCategory = employee.JobCategory;
        editEmployee.AcademicDegree = employee.AcademicDegree;
        isEditingBasicInfo = false;
    }

    private async Task UploadPhoto()
    {
        // TODO: تنفيذ رفع الصور
        await JSRuntime.InvokeVoidAsync("alert", "سيتم تنفيذ رفع الصور قريباً");
    }

    private async Task AddProfessionalEvent()
    {
        await JSRuntime.InvokeVoidAsync("window.location.href", $"/add-event/{EmployeeId}");
    }

    private string GetEventTypeClass(EventType eventType)
    {
        return eventType switch
        {
            EventType.Commendation or EventType.HigherDegree => "positive",
            EventType.NoticePenalty or EventType.WarningPenalty or EventType.ReprimandPenalty => "negative",
            _ => "neutral"
        };
    }

    private string GetEventIcon(EventType eventType)
    {
        return eventType switch
        {
            EventType.Commendation => "fas fa-star",
            EventType.HigherDegree => "fas fa-graduation-cap",
            EventType.NoticePenalty => "fas fa-exclamation-triangle",
            EventType.WarningPenalty => "fas fa-exclamation-circle",
            EventType.ReprimandPenalty => "fas fa-times-circle",
            EventType.UnpaidLeave => "fas fa-calendar-times",
            EventType.DisabilityLeave => "fas fa-wheelchair",
            EventType.FiveYearLeave => "fas fa-calendar-minus",
            EventType.MaternityLeave => "fas fa-baby",
            _ => "fas fa-file-alt"
        };
    }

