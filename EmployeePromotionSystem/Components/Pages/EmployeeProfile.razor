    .timeline-item {
        position: relative;
        margin-bottom: 30px;
        padding-right: 80px;
    }

    .timeline-marker {
        position: absolute;
        right: 15px;
        top: 0;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 0.8rem;
        z-index: 1;
    }

    .timeline-marker.promotion {
        background: linear-gradient(135deg, #2196F3, #1976D2);
    }

    .timeline-marker.allowance {
        background: linear-gradient(135deg, #4CAF50, #45a049);
    }

    .timeline-content {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 20px;
    }

    .timeline-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
    }

    .timeline-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #333;
        margin: 0;
    }

    .timeline-date {
        color: #667eea;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .timeline-description {
        color: #666;
        margin: 0 0 10px 0;
