@page "/employee/{employeeId:int}"
@using EmployeePromotionSystem.Services
@using EmployeePromotionSystem.Models
@inject IEmployeeService EmployeeService
@inject ICalculationEngine CalculationEngine
@inject IJSRuntime JSRuntime

<PageTitle>ملف الموظف - @(employee?.FullName ?? "غير محدد")</PageTitle>

@if (employee == null)
{
    <div class="loading-container">
        <div class="loading-spinner">
            <i class="fas fa-spinner fa-spin"></i>
        </div>
        <p>جاري تحميل بيانات الموظف...</p>
    </div>
}
else
{
    <div class="employee-profile-container">
        <!-- قسم الرأس -->
        <div class="profile-header animate__animated animate__fadeInDown">
            <div class="employee-photo-section">
                <div class="photo-container">
                    @if (!string.IsNullOrEmpty(employee.PhotoPath))
                    {
                        <img src="@employee.PhotoPath" alt="@employee.FullName" class="employee-photo" />
                    }
                    else
                    {
                        <div class="photo-placeholder">
                            <i class="fas fa-user"></i>
                        </div>
                    }
                    <button class="btn btn-sm btn-outline-primary photo-upload-btn" @onclick="UploadPhoto">
                        <i class="fas fa-camera"></i>
                        تحديث الصورة
                    </button>
                </div>
            </div>
            
            <div class="employee-basic-info">
                <div class="name-section">
                    @if (isEditingBasicInfo)
                    {
                        <input @bind="editEmployee.FullName" class="form-control name-input" />
                    }
                    else
                    {
                        <h1 class="employee-name">@employee.FullName</h1>
                    }
                </div>
                
                <div class="info-row">
                    @if (isEditingBasicInfo)
                    {
                        <div class="edit-fields">
                            <select @bind="editEmployee.JobCategory" class="form-control">
                                <option value="تدريسي">تدريسي</option>
                                <option value="إداري">إداري</option>
                                <option value="فني">فني</option>
                                <option value="خدمي">خدمي</option>
                            </select>
                            <input @bind="editEmployee.Title" class="form-control" placeholder="العنوان الوظيفي" />
                            <select @bind="editEmployee.AcademicDegree" class="form-control">
                                <option value="دبلوم">دبلوم</option>
                                <option value="بكالوريوس">بكالوريوس</option>
                                <option value="ماجستير">ماجستير</option>
                                <option value="دكتوراه">دكتوراه</option>
                            </select>
                        </div>
                    }
                    else
                    {
                        <span class="job-category">@employee.JobCategory</span>
                        <span class="job-title">@employee.Title</span>
                        <span class="academic-degree">@employee.AcademicDegree</span>
                    }
                </div>
                
                <div class="status-indicator">
                    <span class="status-dot active"></span>
                    <span class="status-text">في الخدمة</span>
                </div>
            </div>
            
            <div class="header-actions">
                @if (isEditingBasicInfo)
                {
                    <button class="btn btn-success" @onclick="SaveBasicInfo">
                        <i class="fas fa-save"></i>
                        حفظ
                    </button>
                    <button class="btn btn-secondary" @onclick="CancelEditBasicInfo">
                        <i class="fas fa-times"></i>
                        إلغاء
                    </button>
                }
                else
                {
                    <button class="btn btn-primary" @onclick="EditBasicInfo">
                        <i class="fas fa-edit"></i>
                        تعديل البيانات
                    </button>
                }
            </div>
        </div>

        <!-- المؤشرات الرئيسية -->
        <div class="key-metrics animate__animated animate__fadeInUp">
            <div class="row">
                <div class="col-md-4">
                    <div class="metric-card current-position">
                        <div class="metric-icon">
                            <i class="fas fa-award"></i>
                        </div>
                        <div class="metric-content">
                            <h3 class="metric-title">الدرجة والمرحلة الحالية</h3>
                            <div class="metric-value">
                                الدرجة @employee.JobGrade - المرحلة @employee.JobStage
                            </div>
                            <small class="metric-date">
                                تاريخ الاستحقاق: @employee.LastAllowanceDate.ToString("dd/MM/yyyy")
                            </small>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-4">
                    <div class="metric-card next-entitlement">
                        <div class="metric-icon">
                            <i class="fas fa-calendar-alt"></i>
                        </div>
                        <div class="metric-content">
                            <h3 class="metric-title">الاستحقاق القادم</h3>
                            <div class="metric-value">
                                @employee.NextEntitlementType
                                @if (employee.NextEntitlementType == "ترفيع")
                                {
                                    <span class="next-grade">
                                        إلى الدرجة @(employee.JobGrade - 1)
                                    </span>
                                }
                                else
                                {
                                    <span class="next-stage">
                                        إلى المرحلة @(employee.JobStage + 1)
                                    </span>
                                }
                            </div>
                            <small class="metric-date">
                                @nextEntitlementDate.ToString("dd/MM/yyyy")
                                (@daysUntilEntitlement يوم)
                            </small>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-4">
                    <div class="metric-card actual-service">
                        <div class="metric-icon">
                            <i class="fas fa-clock"></i>
                        </div>
                        <div class="metric-content">
                            <h3 class="metric-title">الخدمة الفعلية</h3>
                            <div class="metric-value">
                                @employee.ActualServiceFormatted
                            </div>
                            <small class="metric-date">
                                منذ @employee.StartDate.ToString("dd/MM/yyyy")
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- السجلات التاريخية -->
        <div class="historical-records animate__animated animate__fadeInLeft">
            <div class="records-tabs">
                <ul class="nav nav-tabs" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link @(activeTab == "career" ? "active" : "")" 
                           @onclick="() => SetActiveTab(\"career\")" role="tab">
                            <i class="fas fa-trending-up"></i>
                            المسار الوظيفي
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(activeTab == "events" ? "active" : "")" 
                           @onclick="() => SetActiveTab(\"events\")" role="tab">
                            <i class="fas fa-file-alt"></i>
                            الأحداث المهنية
                        </a>
                    </li>
                </ul>
            </div>
            
            <div class="tab-content">
                @if (activeTab == "career")
                {
                    <div class="career-timeline">
                        @if (promotionHistory != null && promotionHistory.Any())
                        {
                            @foreach (var record in promotionHistory.OrderByDescending(p => p.EffectiveDate))
                            {
                                <div class="timeline-item">
                                    <div class="timeline-marker @(record.Type == PromotionType.Promotion ? "promotion" : "allowance")">
                                        @if (record.Type == PromotionType.Promotion)
                                        {
                                            <i class="fas fa-arrow-up"></i>
                                        }
                                        else
                                        {
                                            <i class="fas fa-plus"></i>
                                        }
                                    </div>
                                    <div class="timeline-content">
                                        <div class="timeline-header">
                                            <h4 class="timeline-title">
                                                @(record.Type == PromotionType.Promotion ? "ترفيع" : "علاوة سنوية")
                                            </h4>
                                            <span class="timeline-date">@record.EffectiveDate.ToString("dd/MM/yyyy")</span>
                                        </div>
                                        <p class="timeline-description">@record.Description</p>
                                        @if (!string.IsNullOrEmpty(record.Impact))
                                        {
                                            <small class="timeline-impact">@record.Impact</small>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="no-records">
                                <i class="fas fa-history"></i>
                                <p>لا توجد سجلات في المسار الوظيفي حتى الآن</p>
                            </div>
                        }
                    </div>
                }
                else if (activeTab == "events")
                {
                    <div class="events-list">
                        @if (professionalEvents != null && professionalEvents.Any())
                        {
                            @foreach (var eventItem in professionalEvents.OrderByDescending(e => e.EventDate))
                            {
                                <div class="event-item @GetEventTypeClass(eventItem.EventType)">
                                    <div class="event-icon">
                                        <i class="@GetEventIcon(eventItem.EventType)"></i>
                                    </div>
                                    <div class="event-content">
                                        <div class="event-header">
                                            <h5 class="event-title">@GetEventTypeName(eventItem.EventType)</h5>
                                            <span class="event-date">@eventItem.EventDate.ToString("dd/MM/yyyy")</span>
                                        </div>
                                        <p class="event-description">@eventItem.Description</p>
                                        @if (!string.IsNullOrEmpty(eventItem.DocumentNumber))
                                        {
                                            <small class="event-document">
                                                رقم الكتاب: @eventItem.DocumentNumber
                                                (@eventItem.DocumentDate?.ToString("dd/MM/yyyy"))
                                            </small>
                                        }
                                        @if (eventItem.ImpactMonths != 0)
                                        {
                                            <div class="event-impact">
                                                التأثير: @(eventItem.ImpactMonths > 0 ? "+" : "")@eventItem.ImpactMonths شهر
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="no-records">
                                <i class="fas fa-calendar-times"></i>
                                <p>لا توجد أحداث مهنية مسجلة</p>
                                <button class="btn btn-primary" @onclick="AddProfessionalEvent">
                                    <i class="fas fa-plus"></i>
                                    إضافة حدث مهني
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

<style>
    .employee-profile-container {
        padding: 20px 0;
        max-width: 1200px;
        margin: 0 auto;
    }

    .profile-header {
        background: white;
        border-radius: 20px;
