@page "/events"
@using EmployeePromotionSystem.Services
@using EmployeePromotionSystem.Models
@inject IEmployeeService EmployeeService
@inject IJSRuntime JSRuntime

<PageTitle>الأحداث المهنية - نظام أتمتة العلاوات والترفيعات</PageTitle>

<div class="events-container">
    <!-- رأس الصفحة -->
    <div class="page-header animate__animated animate__fadeInDown">
        <div class="header-content">
            <h1 class="page-title">
                <i class="fas fa-calendar-alt"></i>
                الأحداث المهنية
            </h1>
            <p class="page-subtitle">إدارة وإضافة الأحداث المهنية للموظفين</p>
        </div>
        <div class="header-actions">
            <button class="btn btn-primary" @onclick="ShowAddEventModal">
                <i class="fas fa-plus"></i>
                إضافة حدث مهني
            </button>
        </div>
    </div>

    <!-- إحصائيات سريعة -->
    <div class="quick-stats animate__animated animate__fadeInUp">
        <div class="row">
            <div class="col-md-3">
                <div class="stat-card positive">
                    <div class="stat-icon">
                        <i class="fas fa-star"></i>
                    </div>
                    <div class="stat-content">
                        <h3 class="stat-number">@positiveEventsCount</h3>
                        <p class="stat-label">كتب الشكر</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card negative">
                    <div class="stat-icon">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                    <div class="stat-content">
                        <h3 class="stat-number">@negativeEventsCount</h3>
                        <p class="stat-label">العقوبات</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card neutral">
                    <div class="stat-icon">
                        <i class="fas fa-calendar-times"></i>
                    </div>
                    <div class="stat-content">
                        <h3 class="stat-number">@leaveEventsCount</h3>
                        <p class="stat-label">الإجازات</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card info">
                    <div class="stat-icon">
                        <i class="fas fa-graduation-cap"></i>
                    </div>
                    <div class="stat-content">
                        <h3 class="stat-number">@degreeEventsCount</h3>
                        <p class="stat-label">الشهادات</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- فلاتر البحث -->
    <div class="search-filters animate__animated animate__fadeInLeft">
        <div class="row">
            <div class="col-md-4">
                <div class="search-box">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" class="form-control" placeholder="البحث في الأحداث..." 
                           @bind="searchTerm" @oninput="OnSearchChanged" />
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-control" @bind="selectedEventType" @bind:after="ApplyFilters">
                    <option value="">جميع أنواع الأحداث</option>
                    <option value="Commendation">كتب الشكر</option>
                    <option value="NoticePenalty">عقوبة لفت نظر</option>
                    <option value="WarningPenalty">عقوبة إنذار</option>
                    <option value="ReprimandPenalty">عقوبة توبيخ</option>
                    <option value="UnpaidLeave">إجازة بدون راتب</option>
                    <option value="HigherDegree">شهادة أعلى</option>
                </select>
            </div>
            <div class="col-md-3">
                <input type="date" class="form-control" @bind="filterDate" @bind:after="ApplyFilters" />
            </div>
            <div class="col-md-2">
                <select class="form-control" @bind="sortBy" @bind:after="ApplyFilters">
                    <option value="date">التاريخ</option>
                    <option value="employee">الموظف</option>
                    <option value="type">النوع</option>
                </select>
            </div>
        </div>
    </div>

    <!-- قائمة الأحداث -->
    <div class="events-list animate__animated animate__fadeInRight">
        @if (isLoading)
        {
            <div class="loading-container">
                <div class="loading-spinner">
                    <i class="fas fa-spinner fa-spin"></i>
                </div>
                <p>جاري تحميل الأحداث المهنية...</p>
            </div>
        }
        else if (filteredEvents != null && filteredEvents.Any())
        {
            @foreach (var eventItem in filteredEvents)
            {
                <div class="event-card @GetEventTypeClass(eventItem.EventType)">
                    <div class="event-header">
                        <div class="event-icon">
                            <i class="@GetEventIcon(eventItem.EventType)"></i>
                        </div>
                        <div class="event-basic-info">
                            <h4 class="event-title">@GetEventTypeName(eventItem.EventType)</h4>
                            <p class="event-employee">@eventItem.Employee.FullName</p>
                            <span class="event-date">@eventItem.EventDate.ToString("dd/MM/yyyy")</span>
                        </div>
                        <div class="event-actions">
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => ViewEventDetails(eventItem.Id)">
                                <i class="fas fa-eye"></i>
                                عرض
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditEvent(eventItem.Id)">
                                <i class="fas fa-edit"></i>
                                تعديل
                            </button>
                        </div>
                    </div>
                    
                    <div class="event-details">
                        <p class="event-description">@eventItem.Description</p>
                        @if (!string.IsNullOrEmpty(eventItem.DocumentNumber))
                        {
                            <div class="event-document">
                                <i class="fas fa-file-alt"></i>
                                رقم الكتاب: @eventItem.DocumentNumber
                                (@eventItem.DocumentDate?.ToString("dd/MM/yyyy"))
                            </div>
                        }
                        @if (eventItem.ImpactMonths != 0)
                        {
                            <div class="event-impact">
                                <i class="fas fa-clock"></i>
                                التأثير: @(eventItem.ImpactMonths > 0 ? "+" : "")@eventItem.ImpactMonths شهر
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="no-data-container">
                <div class="no-data-icon">
                    <i class="fas fa-calendar-times"></i>
                </div>
                <h3>لا توجد أحداث مهنية</h3>
                <p>لم يتم العثور على أحداث مهنية تطابق معايير البحث المحددة</p>
                <button class="btn btn-primary" @onclick="ShowAddEventModal">
                    <i class="fas fa-plus"></i>
                    إضافة حدث مهني جديد
                </button>
            </div>
        }
    </div>
</div>

<style>
    .events-container {
        padding: 20px 0;
    }

    .page-header {
        background: white;
        border-radius: 15px;
        padding: 25px;
        margin-bottom: 25px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .page-title {
        font-size: 2rem;
        font-weight: 700;
        color: #333;
        margin: 0;
        display: flex;
        align-items: center;
    }

    .page-title i {
        margin-left: 15px;
        color: #667eea;
    }

    .page-subtitle {
        color: #666;
        margin: 5px 0 0 0;
        font-size: 1rem;
    }

    .quick-stats {
        margin-bottom: 25px;
    }

    .stat-card {
        background: white;
        border-radius: 15px;
        padding: 20px;
        display: flex;
        align-items: center;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
        cursor: pointer;
        height: 100%;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
    }

    .stat-icon {
        font-size: 2rem;
        margin-left: 15px;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

    .stat-card.positive .stat-icon { background: linear-gradient(135deg, #28a745, #20c997); }
    .stat-card.negative .stat-icon { background: linear-gradient(135deg, #dc3545, #e74c3c); }
    .stat-card.neutral .stat-icon { background: linear-gradient(135deg, #6c757d, #5a6268); }
    .stat-card.info .stat-icon { background: linear-gradient(135deg, #17a2b8, #138496); }

    .stat-content {
        flex: 1;
    }

    .stat-number {
        font-size: 2rem;
        font-weight: 700;
        margin: 0;
        color: #333;
    }

    .stat-label {
        font-size: 0.9rem;
        color: #666;
        margin: 5px 0 0 0;
    }

    .search-filters {
        background: white;
        border-radius: 15px;
        padding: 20px;
        margin-bottom: 25px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }

    .search-box {
        position: relative;
    }

    .search-icon {
        position: absolute;
        right: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: #999;
    }

    .form-control {
        border: 2px solid #e9ecef;
        border-radius: 10px;
        padding: 12px 45px 12px 15px;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .form-control:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
    }

    .events-list {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .event-card {
        background: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
        border-left: 5px solid;
    }

    .event-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
    }

    .event-card.positive {
        border-left-color: #28a745;
        background: linear-gradient(135deg, #ffffff 0%, #f8fff9 100%);
    }

    .event-card.negative {
        border-left-color: #dc3545;
        background: linear-gradient(135deg, #ffffff 0%, #fff8f8 100%);
    }

    .event-card.neutral {
        border-left-color: #6c757d;
        background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
    }

    .event-header {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 15px;
    }

    .event-icon {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        color: white;
        flex-shrink: 0;
    }

    .event-card.positive .event-icon {
        background: linear-gradient(135deg, #28a745, #20c997);
    }

    .event-card.negative .event-icon {
        background: linear-gradient(135deg, #dc3545, #e74c3c);
    }

    .event-card.neutral .event-icon {
        background: linear-gradient(135deg, #6c757d, #5a6268);
    }

    .event-basic-info {
        flex: 1;
    }

    .event-title {
        font-size: 1.2rem;
        font-weight: 600;
        color: #333;
        margin: 0 0 5px 0;
    }

    .event-employee {
        color: #667eea;
        font-weight: 500;
        margin: 0 0 5px 0;
    }

    .event-date {
        color: #999;
        font-size: 0.9rem;
    }

    .event-actions {
        display: flex;
        gap: 10px;
    }

    .event-details {
        padding-top: 15px;
        border-top: 1px solid #eee;
    }

    .event-description {
        color: #666;
        margin: 0 0 10px 0;
        line-height: 1.5;
    }

    .event-document, .event-impact {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
        margin-bottom: 5px;
    }

    .event-document {
        color: #17a2b8;
    }

    .event-impact {
        font-weight: 600;
    }

    .event-card.positive .event-impact {
        color: #28a745;
    }

    .event-card.negative .event-impact {
        color: #dc3545;
    }

    .event-card.neutral .event-impact {
        color: #6c757d;
    }

    .btn {
        border-radius: 8px;
        font-weight: 500;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    }

    .loading-container, .no-data-container {
        text-align: center;
        padding: 60px 20px;
        color: #666;
    }

    .loading-spinner i {
        font-size: 3rem;
        color: #667eea;
        margin-bottom: 20px;
    }

    .no-data-icon i {
        font-size: 4rem;
        color: #ccc;
        margin-bottom: 20px;
    }

    @media (max-width: 768px) {
        .page-header {
            flex-direction: column;
            text-align: center;
            gap: 20px;
        }

        .event-header {
            flex-direction: column;
            text-align: center;
            gap: 15px;
        }

        .event-actions {
            justify-content: center;
        }
    }
</style>

@code {
    private List<ProfessionalEvent>? allEvents;
    private List<ProfessionalEvent>? filteredEvents;
    private bool isLoading = true;

    private string searchTerm = "";
    private string selectedEventType = "";
    private DateTime? filterDate;
    private string sortBy = "date";

    private int positiveEventsCount = 0;
    private int negativeEventsCount = 0;
    private int leaveEventsCount = 0;
    private int degreeEventsCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadEvents();
    }

    private async Task LoadEvents()
    {
        try
        {
            isLoading = true;
            allEvents = await EmployeeService.GetAllProfessionalEventsAsync();
            CalculateStats();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"خطأ في تحميل الأحداث: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void CalculateStats()
    {
        if (allEvents == null) return;

        positiveEventsCount = allEvents.Count(e => e.EventType == EventType.Commendation);
        negativeEventsCount = allEvents.Count(e => 
            e.EventType == EventType.NoticePenalty || 
            e.EventType == EventType.WarningPenalty || 
            e.EventType == EventType.ReprimandPenalty);
        leaveEventsCount = allEvents.Count(e => 
            e.EventType == EventType.UnpaidLeave || 
            e.EventType == EventType.DisabilityLeave || 
            e.EventType == EventType.FiveYearLeave || 
            e.EventType == EventType.MaternityLeave);
        degreeEventsCount = allEvents.Count(e => e.EventType == EventType.HigherDegree);
    }

    private void ApplyFilters()
    {
        if (allEvents == null) return;

        filteredEvents = allEvents.AsEnumerable();

        // تطبيق البحث
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredEvents = filteredEvents.Where(e => 
                e.Employee.FullName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                e.Description.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                (e.DocumentNumber?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        // تطبيق فلتر نوع الحدث
        if (!string.IsNullOrWhiteSpace(selectedEventType) && Enum.TryParse<EventType>(selectedEventType, out var eventType))
        {
            filteredEvents = filteredEvents.Where(e => e.EventType == eventType);
        }

        // تطبيق فلتر التاريخ
        if (filterDate.HasValue)
        {
            filteredEvents = filteredEvents.Where(e => e.EventDate.Date == filterDate.Value.Date);
        }

        // تطبيق الترتيب
        filteredEvents = sortBy switch
        {
            "date" => filteredEvents.OrderByDescending(e => e.EventDate),
            "employee" => filteredEvents.OrderBy(e => e.Employee.FullName),
            "type" => filteredEvents.OrderBy(e => e.EventType),
            _ => filteredEvents.OrderByDescending(e => e.EventDate)
        };

        filteredEvents = filteredEvents.ToList();
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        ApplyFilters();
        await Task.Delay(1);
    }

    private async Task ShowAddEventModal()
    {
        await JSRuntime.InvokeVoidAsync("window.location.href", "/add-event");
    }

    private async Task ViewEventDetails(int eventId)
    {
        await JSRuntime.InvokeVoidAsync("window.location.href", $"/event/{eventId}");
    }

    private async Task EditEvent(int eventId)
    {
        await JSRuntime.InvokeVoidAsync("window.location.href", $"/edit-event/{eventId}");
    }

    private string GetEventTypeClass(EventType eventType)
    {
        return eventType switch
        {
            EventType.Commendation or EventType.HigherDegree => "positive",
            EventType.NoticePenalty or EventType.WarningPenalty or EventType.ReprimandPenalty => "negative",
            _ => "neutral"
        };
    }

    private string GetEventIcon(EventType eventType)
    {
        return eventType switch
        {
            EventType.Commendation => "fas fa-star",
            EventType.HigherDegree => "fas fa-graduation-cap",
            EventType.NoticePenalty => "fas fa-exclamation-triangle",
            EventType.WarningPenalty => "fas fa-exclamation-circle",
            EventType.ReprimandPenalty => "fas fa-times-circle",
            EventType.UnpaidLeave => "fas fa-calendar-times",
            EventType.DisabilityLeave => "fas fa-wheelchair",
            EventType.FiveYearLeave => "fas fa-calendar-minus",
            EventType.MaternityLeave => "fas fa-baby",
            _ => "fas fa-file-alt"
        };
    }

    private string GetEventTypeName(EventType eventType)
    {
        return eventType switch
        {
            EventType.Commendation => "كتاب شكر وتقدير",
            EventType.HigherDegree => "الحصول على شهادة أعلى",
            EventType.NoticePenalty => "عقوبة لفت نظر",
            EventType.WarningPenalty => "عقوبة إنذار",
            EventType.ReprimandPenalty => "عقوبة توبيخ",
            EventType.UnpaidLeave => "إجازة بدون راتب",
            EventType.DisabilityLeave => "إجازة رعاية المعاقين",
            EventType.FiveYearLeave => "إجازة الخمس سنوات",
            EventType.MaternityLeave => "إجازة أمومة",
            EventType.Custom => "حدث مخصص",
            _ => "حدث غير محدد"
        };
    }
}
